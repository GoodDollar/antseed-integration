# Local wrangler dev values. Copy to .dev.vars and never commit real secrets.
ANTSEED_BASE_URL=http://127.0.0.1:8377
ANTSEED_MODEL=qwen3-235b-instruct
ANTSEED_TIMEOUT_MS=120000
PRICE_MICRO_USD_PER_1K_INPUT_TOKENS=500
PRICE_MICRO_USD_PER_1K_OUTPUT_TOKENS=1500
DEFAULT_MAX_OUTPUT_TOKENS=1024
MIN_RESERVE_MICRO_USD=1000
CREDIT_TOKEN_DECIMALS=6
GD_MICRO_USD_PER_TOKEN=1000000
# CELO_RPC_URL=https://forno.celo.org
# CELO_VAULT_ADDRESS=0x...
# CELO_GOODID_ADDRESS=0x...

# Optional AgentCreditVault accounting integration only; this does not pay AntSeed
# RPC_URL=http://127.0.0.1:8545
# VAULT_ADDRESS=0x...
# OPERATOR_PRIVATE_KEY=0x...

# Optional Base USDC vault that actually funds the backend AntSeed buyer deposit
# ANTSEED_FUNDING_RPC_URL=https://base.publicnode.com
# ANTSEED_FUNDING_VAULT_ADDRESS=0x...
# ANTSEED_FUNDING_OPERATOR_PRIVATE_KEY=0x...
# ANTSEED_MIN_BUYER_DEPOSIT_MICRO_USD=10000000

# ANTSEED_PIN_PEER=
# ANTSEED_PIN_SERVICE=

# Auth defaults
AUTH_NONCE_TTL_SECONDS=600
# API_KEY_TTL_SECONDS=2592000
# Local/dev only. Keep false in production; true enables gd:0x... account selectors without wallet signature proof.
ALLOW_UNVERIFIED_ACCOUNT_SELECTOR=false
