{
  "name": "@gooddollar/antseed-integration-worker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for GoodDollar AntSeed credit accounting and buyer integration",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist/worker",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "ethers": "^6.13.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260518.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.18.0"
  }
}
